<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Due_Date_Field_Check</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISBLANK(Due_Date__c),
    Is_Completed__c = FALSE
)</errorConditionFormula>
    <errorDisplayField>Due_Date__c</errorDisplayField>
    <errorMessage>Due Date is mandatory. Please enter a due date to save this task.</errorMessage>
</ValidationRule>
